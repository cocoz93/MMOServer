{
  "uid": "echo-stress-client",
  "title": "Echo Stress Client",
  "tags": ["stress", "echo", "client"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "row",
      "title": "연결 & 트래픽",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "연결 수",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "textMode": "auto" },
      "targets": [{
        "expr": "stress_connected_clients",
        "legendFormat": "Connected",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "접속 시도 / 실패",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": [{
          "matcher": { "id": "byName", "options": "Fail" },
          "properties": [{ "id": "thresholds", "value": { "steps": [{ "color": "red", "value": null }] } }]
        }]
      },
      "options": { "graphMode": "area", "colorMode": "background", "textMode": "auto" },
      "targets": [
        { "expr": "stress_connect_total", "legendFormat": "Total", "refId": "A" },
        { "expr": "stress_connect_fail_total", "legendFormat": "Fail", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "초당 패킷 (send / recv)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "pps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(stress_send_packets_total[1m])", "legendFormat": "send pkt/s", "refId": "A" },
        { "expr": "rate(stress_recv_packets_total[1m])", "legendFormat": "recv pkt/s", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "연결 수 추이",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [{
        "expr": "stress_connected_clients",
        "legendFormat": "Connected",
        "refId": "A"
      }]
    },

    {
      "type": "row",
      "title": "RTT (Round-Trip Time)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "RTT 평균 (ms)",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "textMode": "auto" },
      "targets": [{
        "expr": "rate(stress_rtt_seconds_sum[1m]) / rate(stress_rtt_seconds_count[1m]) * 1000",
        "legendFormat": "avg RTT",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "RTT Percentile (ms)",
      "gridPos": { "h": 6, "w": 10, "x": 4, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          },
          "custom": { "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(stress_rtt_seconds_bucket[1m])) * 1000", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.99, rate(stress_rtt_seconds_bucket[1m])) * 1000", "legendFormat": "p99", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "RTT 분포 (버킷별 rate)",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 8 },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "targets": [{
        "expr": "rate(stress_rtt_seconds_bucket[1m])",
        "legendFormat": "le={{le}}",
        "refId": "A"
      }]
    },

    {
      "type": "row",
      "title": "에러",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "에러 발생률",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(stress_disconnect_from_server_total[1m])", "legendFormat": "server disconnect/s", "refId": "A" },
        { "expr": "rate(stress_echo_not_recv_total[1m])", "legendFormat": "echo timeout/s", "refId": "B" },
        { "expr": "rate(stress_packet_error_total[1m])", "legendFormat": "packet error/s", "refId": "C" },
        { "expr": "rate(stress_late_arrival_total[1m])", "legendFormat": "late arrival/s", "refId": "D" },
        { "expr": "rate(stress_send_buffer_full_total[1m])", "legendFormat": "send buf full/s", "refId": "E" }
      ]
    },
    {
      "type": "stat",
      "title": "에러 누적",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "textMode": "auto" },
      "targets": [
        { "expr": "stress_connect_fail_total", "legendFormat": "Connect Fail", "refId": "A" },
        { "expr": "stress_disconnect_from_server_total", "legendFormat": "Server Disconnect", "refId": "B" },
        { "expr": "stress_echo_not_recv_total", "legendFormat": "Echo Timeout", "refId": "C" },
        { "expr": "stress_packet_error_total", "legendFormat": "Packet Error", "refId": "D" },
        { "expr": "stress_late_arrival_total", "legendFormat": "Late Arrival", "refId": "E" },
        { "expr": "stress_send_buffer_full_total", "legendFormat": "Send Buf Full", "refId": "F" }
      ]
    },

    {
      "type": "row",
      "title": "클라이언트 상태",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "미응답 에코 패킷 (pending)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "custom": { "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "targets": [{
        "expr": "stress_pending_packets",
        "legendFormat": "pending packets",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "클라이언트 루프 소요 시간 (ms)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "custom": { "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "targets": [{
        "expr": "stress_loop_duration_seconds * 1000",
        "legendFormat": "loop duration",
        "refId": "A"
      }]
    },

    {
      "type": "row",
      "title": "시스템 리소스 (windows_exporter)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "프로세스 CPU 사용률 (%)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 29 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 90 }
            ]
          },
          "custom": { "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(windows_process_cpu_time_total{process=\"IOCP_Server\"}[30s]) * 100", "legendFormat": "IOCP_Server", "refId": "A" },
        { "expr": "rate(windows_process_cpu_time_total{process=\"EchoStressClient\"}[30s]) * 100", "legendFormat": "EchoStressClient", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "시스템 전체 CPU 사용률 (%)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 29 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "custom": { "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "(1 - avg(rate(windows_cpu_time_total{mode=\"idle\"}[30s]))) * 100", "legendFormat": "전체 CPU", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "프로세스 메모리 (Working Set)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "windows_process_working_set_bytes{process=\"IOCP_Server\"}", "legendFormat": "IOCP_Server", "refId": "A" },
        { "expr": "windows_process_working_set_bytes{process=\"EchoStressClient\"}", "legendFormat": "EchoStressClient", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "시스템 메모리 사용률 (%)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          },
          "custom": { "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "(1 - windows_os_physical_memory_free_bytes / windows_cs_physical_memory_bytes) * 100", "legendFormat": "메모리 사용률", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
