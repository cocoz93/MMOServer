{
  "uid": "iocp-mmo-server",
  "title": "IOCP MMO Server",
  "tags": ["mmo", "iocp"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "row",
      "title": "서버 핵심 지표",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "동접 수",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "textMode": "auto" },
      "targets": [{
        "expr": "mmo_session_count",
        "legendFormat": "Sessions",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "세션 생성/소멸 (누적)",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "textMode": "auto" },
      "targets": [
        { "expr": "mmo_session_created_total", "legendFormat": "Created", "refId": "A" },
        { "expr": "mmo_session_destroyed_total", "legendFormat": "Destroyed", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "초당 패킷 (recv / send)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "pps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(mmo_recv_packets_total[1m])", "legendFormat": "recv pkt/s", "refId": "A" },
        { "expr": "rate(mmo_send_packets_total[1m])", "legendFormat": "send pkt/s", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "트래픽 (KB/s)",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "KBs", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(mmo_recv_bytes_total[1m]) / 1024", "legendFormat": "recv KB/s", "refId": "A" },
        { "expr": "rate(mmo_send_bytes_total[1m]) / 1024", "legendFormat": "send KB/s", "refId": "B" }
      ]
    },

    {
      "type": "row",
      "title": "Tick 성능",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Tick 평균 (ms)",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "textMode": "auto" },
      "targets": [{
        "expr": "rate(mmo_tick_duration_seconds_sum[1m]) / rate(mmo_tick_duration_seconds_count[1m]) * 1000",
        "legendFormat": "avg",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Tick 99th Percentile (ms)",
      "gridPos": { "h": 6, "w": 10, "x": 4, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "custom": { "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(mmo_tick_duration_seconds_bucket[1m])) * 1000",
        "legendFormat": "p99",
        "refId": "A"
      }]
    },
    {
      "type": "heatmap",
      "title": "Tick 분포 (히트맵)",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 8 },
      "options": {
        "calculate": false,
        "color": { "scheme": "Oranges", "fill": "dark", "exponent": 0.5 },
        "yAxis": { "unit": "s" },
        "cellGap": 1,
        "tooltip": { "show": true }
      },
      "targets": [{
        "expr": "rate(mmo_tick_duration_seconds_bucket[1m])",
        "legendFormat": "{{le}}",
        "format": "heatmap",
        "refId": "A"
      }]
    },

    {
      "type": "row",
      "title": "게임 루프 상세",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Tick 구간별 소비 시간 (ms/tick)",
      "gridPos": { "h": 6, "w": 10, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(mmo_tick_phase_seconds_total{phase=\"network_dispatch\"}[1m]) / rate(mmo_tick_duration_seconds_count[1m]) * 1000", "legendFormat": "network_dispatch", "refId": "A" },
        { "expr": "rate(mmo_tick_phase_seconds_total{phase=\"game_logic\"}[1m]) / rate(mmo_tick_duration_seconds_count[1m]) * 1000", "legendFormat": "game_logic", "refId": "B" },
        { "expr": "rate(mmo_tick_phase_seconds_total{phase=\"broadcast_sync\"}[1m]) / rate(mmo_tick_duration_seconds_count[1m]) * 1000", "legendFormat": "broadcast_sync", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "이벤트 큐 크기",
      "gridPos": { "h": 6, "w": 6, "x": 10, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "custom": { "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "targets": [{
        "expr": "mmo_event_queue_size",
        "legendFormat": "queue size",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "브로드캐스트 비용",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 15 },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(mmo_broadcast_calls_total[1m])", "legendFormat": "calls/s", "refId": "A" },
        { "expr": "rate(mmo_broadcast_targets_total[1m])", "legendFormat": "targets/s", "refId": "B" },
        { "expr": "rate(mmo_broadcast_targets_total[1m]) / rate(mmo_broadcast_calls_total[1m])", "legendFormat": "avg targets/call", "refId": "C" }
      ]
    },

    {
      "type": "row",
      "title": "에러 & 이상 징후",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "패킷 에러 / 치트 감지",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(mmo_packet_errors_total[1m])", "legendFormat": "packet errors/s", "refId": "A" },
        { "expr": "rate(mmo_cheat_detected_total[1m])", "legendFormat": "cheat/s", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "큐 오버플로 / 타임아웃",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 22 },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(mmo_send_queue_overflow_total[1m])", "legendFormat": "sendQ overflow/s", "refId": "A" },
        { "expr": "rate(mmo_recv_buffer_overflow_total[1m])", "legendFormat": "recvBuf overflow/s", "refId": "B" },
        { "expr": "rate(mmo_session_timed_out_total[1m])", "legendFormat": "timeout/s", "refId": "C" },
        { "expr": "rate(mmo_partial_send_total[1m])", "legendFormat": "partial send/s", "refId": "D" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Accept 실패 / 존 이동",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 22 },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(mmo_accept_failed_total[1m])", "legendFormat": "accept fail/s", "refId": "A" },
        { "expr": "rate(mmo_zone_change_total[1m])", "legendFormat": "zone change/s", "refId": "B" },
        { "expr": "rate(mmo_session_created_total[1m])", "legendFormat": "session create/s", "refId": "C" },
        { "expr": "rate(mmo_session_destroyed_total[1m])", "legendFormat": "session destroy/s", "refId": "D" }
      ]
    },

    {
      "type": "row",
      "title": "Send/Recv 병목 분석",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Send 경합 & WSASend 호출",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 29 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(mmo_send_contention_total[1m])", "legendFormat": "send contention/s", "refId": "A" },
        { "expr": "rate(mmo_wsa_send_calls_total[1m])", "legendFormat": "WSASend calls/s", "refId": "B" },
        { "expr": "rate(mmo_wsa_send_completions_total[1m])", "legendFormat": "WSASend completions/s", "refId": "C" },
        { "expr": "rate(mmo_send_packets_total[1m]) / rate(mmo_wsa_send_completions_total[1m])", "legendFormat": "packets/completion (batch)", "refId": "D" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Send 체류량 (bytes)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 29 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [{
        "expr": "mmo_send_enqueued_bytes_total - mmo_send_bytes_total - mmo_send_discarded_bytes_total",
        "legendFormat": "pending bytes",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Recv 호출 & 효율",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 29 },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(mmo_wsa_recv_calls_total[1m])", "legendFormat": "WSARecv calls/s", "refId": "A" },
        { "expr": "rate(mmo_recv_packets_total[1m]) / rate(mmo_wsa_recv_calls_total[1m])", "legendFormat": "packets/call", "refId": "B" }
      ]
    },

    {
      "type": "row",
      "title": "워커 스레드",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "워커별 IOCP 완료 처리량 (/s)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 5 } },
        "overrides": []
      },
      "targets": [{
        "expr": "rate(mmo_worker_completions_total[1m])",
        "legendFormat": "worker-{{worker}}",
        "refId": "A"
      }]
    },

    {
      "type": "row",
      "title": "OS 지표 (windows_exporter)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU 사용률 (%)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 43 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "custom": { "fillOpacity": 15, "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "targets": [{
        "expr": "1 - avg(rate(windows_cpu_time_total{mode=\"idle\"}[1m]))",
        "legendFormat": "CPU %",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "메모리 사용량",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 43 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 15 } },
        "overrides": []
      },
      "targets": [
        { "expr": "windows_os_visible_memory_bytes - windows_os_physical_memory_free_bytes", "legendFormat": "Used", "refId": "A" },
        { "expr": "windows_os_visible_memory_bytes", "legendFormat": "Total", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "네트워크 I/O (KB/s)",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 43 },
      "fieldConfig": {
        "defaults": { "unit": "KBs", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(windows_net_bytes_received_total[1m]) / 1024", "legendFormat": "recv {{nic}}", "refId": "A" },
        { "expr": "rate(windows_net_bytes_sent_total[1m]) / 1024", "legendFormat": "send {{nic}}", "refId": "B" }
      ]
    },

    {
      "type": "row",
      "title": "서버 처리 지연 (handle-latency / RTT 분해)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Handle Latency 평균 (ms)",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 50 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 40 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "textMode": "auto" },
      "targets": [{
        "expr": "rate(mmo_handle_latency_seconds_sum[1m]) / rate(mmo_handle_latency_seconds_count[1m]) * 1000",
        "legendFormat": "avg",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Handle Latency p50 / p99 (ms)",
      "gridPos": { "h": 6, "w": 10, "x": 4, "y": 50 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "red", "value": 80 }
            ]
          },
          "custom": { "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(mmo_handle_latency_seconds_bucket[1m])) * 1000", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.99, rate(mmo_handle_latency_seconds_bucket[1m])) * 1000", "legendFormat": "p99", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "RTT 분해: 클라RTT = 서버handle + (네트워크+더미)",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 50 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "rate(mmo_dummy_rtt_seconds_sum[1m]) / rate(mmo_dummy_rtt_seconds_count[1m]) * 1000", "legendFormat": "클라 RTT(왕복)", "refId": "A" },
        { "expr": "rate(mmo_handle_latency_seconds_sum[1m]) / rate(mmo_handle_latency_seconds_count[1m]) * 1000", "legendFormat": "서버 handle", "refId": "B" },
        { "expr": "(rate(mmo_dummy_rtt_seconds_sum[1m]) / rate(mmo_dummy_rtt_seconds_count[1m]) - rate(mmo_handle_latency_seconds_sum[1m]) / rate(mmo_handle_latency_seconds_count[1m])) * 1000", "legendFormat": "네트워크+더미(나머지)", "refId": "C" }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 4
}
